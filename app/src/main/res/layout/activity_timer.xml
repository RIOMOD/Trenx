<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivExerciseVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@color/card_dark" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_overlay" />

        <TextView
            android:id="@+id/tvExerciseNameTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:padding="16dp"
            android:text="STANDARD PUSH-UPS"
            android:textColor="@color/accent_color"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:gravity="center"/>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:45"
            android:textColor="@color/text_white"
            android:textSize="100sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed-light"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GIÂY"
            android:textColor="@color/text_grey"
            android:textSize="14sp"
            android:letterSpacing="0.2"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <ImageButton
            android:id="@+id/btnPrevious"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_media_previous"
            android:backgroundTint="@color/card_dark"
            android:contentDescription="Bài trước"
            android:layout_marginEnd="16dp"
            app:tint="@color/text_white"/>

        <Button
            android:id="@+id/btnStartPause"
            android:layout_width="150dp"
            android:layout_height="70dp"
            android:text="BẮT ĐẦU"
            android:textSize="18sp"
            android:backgroundTint="@color/accent_color"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            app:cornerRadius="35dp" />

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@android:drawable/ic_media_next"
            android:backgroundTint="@color/card_dark"
            android:contentDescription="Bài tiếp theo"
            android:layout_marginStart="16dp"
            app:tint="@color/text_white"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="ĐẶT LẠI ĐỒNG HỒ"
        android:textSize="12sp"
        android:backgroundTint="@android:color/transparent"
        android:textColor="@color/text_grey" />

</LinearLayout>