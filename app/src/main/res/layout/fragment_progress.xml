<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAEAEA"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- ================= HEADER: Settings | Title | Notification ================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_settings"
                app:tint="#000000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Progress"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_notification"
                    app:tint="#000000" />

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="-6dp"
                    android:background="@drawable/bg_circle_red"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ================= THÔNG TIN CÁ NHÂN ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp">
            <androidx.cardview.widget.CardView
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#D0D0D0"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nguyen Cong Tru"
                    android:textColor="#000000"
                    android:textSize="22sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvUserLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Intermediate  •  Build Strength"
                    android:textColor="#666666"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= CÁC THẺ THỐNG KÊ ================= -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <!-- Thẻ Workouts -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_muscle"
                            app:tint="#555555" />
                        <TextView
                            android:id="@+id/tvTotalWorkouts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="936 Workouts"
                            android:textColor="#000000"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <!-- Thẻ Followers -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_heart"
                            app:tint="#555555" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="16 Followers"
                            android:textColor="#000000"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <!-- Thẻ Following -->
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_heart"
                            app:tint="#555555" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="7 Following"
                            android:textColor="#000000"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ================= THANH CHUYỂN TAB ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="#DFDFDF"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="4dp">

                <!-- Tab Previous Workouts -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/tab_previous_workouts"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="1dp">
                    <TextView
                        android:id="@+id/tv_tab_previous"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Previous Workouts"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <!-- Tab Personal Heatmap -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/tab_personal_heatmap"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@android:color/transparent"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:id="@+id/tv_tab_heatmap"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Personal Heatmap"
                        android:textColor="#666666"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= TAB CONTENT: PREVIOUS WORKOUTS ================= -->
        <LinearLayout
            android:id="@+id/content_previous_workouts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- CALENDAR HEADER: Title + Today button -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp">

                <TextView
                    android:id="@+id/tvCalendarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calendar"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvTodayBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/tvCalendarTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvCalendarTitle" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Month & Navigation arrows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/btn_prev_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#000000" />
                <TextView
                    android:id="@+id/tv_month_year"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="May 2026"
                    android:textColor="#000000"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/btn_next_month"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="#000000" />
            </LinearLayout>

            <!-- Day of week headers (Mo Tu We Th Fr Sa Su) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:weightSum="7">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Mo" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Tu" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="We" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Th" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Fr" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sa" android:textColor="#000000" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Su" android:textColor="#000000" android:textStyle="bold" />
            </LinearLayout>

            <!-- Dynamic Calendar Grid — populated by Java code -->
            <LinearLayout
                android:id="@+id/calendar_grid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <!-- ================= STREAK STATS ================= -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#F4F4F4"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_current_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Days"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Current Streak"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:background="#D0D0D0" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_longest_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Days"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="16sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Longest Streak"
                            android:textColor="#333333"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="32dp"
                android:background="#D0D0D0" />

            <!-- Day Title: "Today, 28 May" -->
            <TextView
                android:id="@+id/tv_date_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="32dp"
                android:text="Today, 28 May"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- ================= ACTIVITY DISPLAY (DYNAMIC) ================= -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <!-- STATE 1: NO ACTIVITIES (default visible) -->
                <LinearLayout
                    android:id="@+id/layout_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="visible">
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@mipmap/ic_launcher"
                        android:alpha="0.4" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="No Activities Yet"
                        android:textColor="#888888"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <Button
                        android:id="@+id/btn_explore_activities"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginHorizontal="32dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Explore Activities"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="28dp" />
                </LinearLayout>

                <!-- STATE 2: HAS WORKOUT HISTORY (default gone) -->
                <LinearLayout
                    android:id="@+id/layout_history_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- User + time ago row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nguyen Cong Tru"
                            android:textColor="#000000"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                        <TextView
                            android:id="@+id/tv_history_days_ago"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textColor="#666666"
                            android:textSize="12sp" />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_more_horiz"
                            app:tint="#666666" />
                    </LinearLayout>

                    <!-- Workout Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_workout_history"
                        android:layout_width="match_parent"
                        android:layout_height="240dp"
                        android:layout_marginTop="16dp"
                        app:cardElevation="0dp">
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="#D3D3D3"
                                android:scaleType="centerCrop" />
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/gradient_overlay" />

                            <!-- Progress indicator top right -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_gravity="top|end"
                                android:gravity="end"
                                android:padding="16dp">
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="6dp"
                                    android:background="#000000" />
                                <TextView
                                    android:id="@+id/tv_history_progress_pct"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100%"
                                    android:textColor="#000000"
                                    android:textStyle="bold"
                                    android:textSize="18sp"
                                    android:layout_marginTop="4dp" />
                            </LinearLayout>

                            <!-- Bottom info -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_gravity="bottom"
                                android:padding="16dp">
                                <ImageView
                                    android:layout_width="60dp"
                                    android:layout_height="60dp"
                                    android:src="@drawable/ic_muscle"
                                    app:tint="#FFFFFF" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="8dp">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="Started a Workout"
                                        android:textColor="#FFFFFF"
                                        android:textStyle="bold"
                                        android:textSize="20sp" />
                                    <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/bg_circle_gray"
                                        android:backgroundTint="#FFFFFF"
                                        android:padding="6dp"
                                        android:src="@drawable/ic_arrow_forward"
                                        app:tint="#000000" />
                                </LinearLayout>
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:layout_marginTop="12dp">
                                    <TextView
                                        android:id="@+id/tv_history_progress_text"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="100% Progress"
                                        android:textColor="#FFFFFF"
                                        android:textSize="14sp" />
                                    <TextView
                                        android:id="@+id/tv_history_time"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:text="00:00 Time"
                                        android:textColor="#FFFFFF"
                                        android:textSize="14sp" />
                                    <TextView
                                        android:id="@+id/tv_history_difficulty"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="end"
                                        android:text="Intermediate"
                                        android:textColor="#FFFFFF"
                                        android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Likes + Comments bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:orientation="horizontal"
                        android:background="#FFFFFF"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_circle_gray"
                                android:backgroundTint="#F4F4F4"
                                android:padding="8dp"
                                android:src="@drawable/ic_heart"
                                app:tint="#000000" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0 Likes"
                                android:textColor="#000000"
                                android:textSize="14sp" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginStart="24dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_circle_gray"
                                android:backgroundTint="#F4F4F4"
                                android:padding="8dp"
                                android:src="@drawable/ic_comment"
                                app:tint="#000000" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0 Comments"
                                android:textColor="#000000"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <!-- ================= TAB CONTENT: PERSONAL HEATMAP ================= -->
        <LinearLayout
            android:id="@+id/content_personal_heatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="32dp">

            <!-- Trained Muscles Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:text="Trained Muscles"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Body Diagrams: Front + Back -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Front view -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="280dp"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/iv_body_front_base"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/body_front"
                        android:scaleType="fitCenter" />

                    <!-- Masks for Front -->
                    <ImageView
                        android:id="@+id/iv_mask_chest"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/mask_chest_front"
                        android:scaleType="fitCenter"
                        app:tint="#9E9E9E" />

                    <ImageView
                        android:id="@+id/iv_mask_abs"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/mask_abs_front"
                        android:scaleType="fitCenter"
                        app:tint="#9E9E9E" />

                    <ImageView
                        android:id="@+id/iv_mask_legs_front"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/mask_legs_front"
                        android:scaleType="fitCenter"
                        app:tint="#9E9E9E" />
                </FrameLayout>

                <!-- Back view -->
                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="280dp"
                    android:layout_weight="1">

                    <ImageView
                        android:id="@+id/iv_body_back_base"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/body_back"
                        android:scaleType="fitCenter" />

                    <!-- Masks for Back -->
                    <ImageView
                        android:id="@+id/iv_mask_back"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/mask_back_rear"
                        android:scaleType="fitCenter"
                        app:tint="#9E9E9E" />

                    <ImageView
                        android:id="@+id/iv_mask_shoulders"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/mask_shoulders_rear"
                        android:scaleType="fitCenter"
                        app:tint="#9E9E9E" />
                </FrameLayout>
            </LinearLayout>

            <!-- Legend -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- 1 Day Ago -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_dot_red" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="1 Day Ago"
                        android:textColor="#333333"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="24dp"
                        android:layout_height="0dp" />

                    <!-- 2-3 Days Ago -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_dot_orange" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="2~3 Days Ago"
                        android:textColor="#333333"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="24dp"
                        android:layout_height="0dp" />

                    <!-- 4+ Days Ago -->
                    <View
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/bg_dot_gray_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="4+ Days Ago"
                        android:textColor="#333333"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Muscle Groups Detail -->
            <LinearLayout
                android:id="@+id/layout_muscle_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginHorizontal="16dp"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>