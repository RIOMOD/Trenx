<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@android:drawable/btn_star_big_on"
        app:tint="@color/accent_color"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TUYỆT VỜI!"
        android:textColor="@color/text_white"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bạn cảm thấy buổi tập hôm nay thế nào?"
        android:textColor="@color/text_grey"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:numStars="5"
        android:stepSize="1"
        android:progressTint="@color/accent_color"
        android:progressBackgroundTint="@color/text_grey"/>

    <Button
        android:id="@+id/btnFinishReview"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="50dp"
        android:text="GỬI ĐÁNH GIÁ &amp; KẾT THÚC"
        android:backgroundTint="@color/accent_color"
        android:textColor="@color/bg_dark"
        android:textStyle="bold"
        app:cornerRadius="30dp"/>

</LinearLayout>